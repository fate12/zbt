# ═══════════════════════════════════════════════════════════════════════
#  主播通 API 服务 — 环境变量模板
#  复制本文件为 .env 并填入真实值（.env 已被 gitignore，不会提交）
#  按三方平台分组，换配置时只看对应分组即可
#
#  ⚠️ 生产部署（阿里云 ECS）：真实密钥只放在服务器的 .env 里，
#     绝不进代码仓库，也不进 GitHub Secrets（仅前端构建变量 VITE_* 才走 Secrets）。
# ═══════════════════════════════════════════════════════════════════════


# ───────────────────────────────────────────────────────────────────────
#  ① 阿里云百炼 / DashScope（AI 大模型 + 知识库 RAG）
#  控制台：https://bailian.console.aliyun.com
#  影响功能：AI 聊天、活动推荐、知识库检索
# ───────────────────────────────────────────────────────────────────────

# API-KEY：百炼控制台 → 右上角头像 → API-KEY 管理
DASHSCOPE_API_KEY=

# 默认对话模型（可换 qwen-plus / qwen-max / qwen-turbo 等）
DASHSCOPE_MODEL=qwen-plus

# 文本向量化模型（知识库索引用，一般无需改）
EMBEDDING_MODEL=text-embedding-v3

# 百炼应用 ID —— 「主播通」主应用（聊天/问答）
# 控制台 → 应用开发 → 我的应用 → 调用方式 → 应用ID
BAILIAN_APP_ID=

# 百炼应用 ID —— 活动推荐（按需，如活动推荐走独立应用）
# 注：当前活动推荐通过下方索引检索后由主应用生成，此项可留空
# BAILIAN_ACTIVITY_APP_ID=

# 知识库索引 ID —— 活动推荐专用索引
# 控制台 → 数据管理 → 知识索引（必须与 API-KEY 同一工作空间）
BAILIAN_ACTIVITY_INDEX_ID=

# 知识库索引 ID —— 默认/通用索引（按需）
BAILIAN_DEFAULT_INDEX_ID=

# 知识库「命中」最低相关性分数（rerank 分数，0~1）。低于此分视为未命中 → AI 助手走通用模型兜底。
# 需用真实语料微调；留空默认 0.35。设为 0 表示「有返回即命中」。
BAILIAN_KB_HIT_MIN_SCORE=0.35

# 工作空间 ID（形如 llm-xxxxxxxx）
# 路径：控制台任意页面 URL 中的 workspaceId 参数
# 多资源在同一工作空间时必填，否则检索会被拒(App.AccessDenied)
BAILIAN_WORKSPACE_ID=


# ───────────────────────────────────────────────────────────────────────
#  ② 阿里云 RDS PostgreSQL（数据库）
#  控制台：https://rdsnext.console.aliyun.com
#  影响功能：全部数据读写、鉴权身份
# ───────────────────────────────────────────────────────────────────────

# 完整连接串（含 sslmode；阿里云 RDS 默认开启 SSL）
# 形如：postgresql://user:pass@rm-xxx.pg.rds.aliyuncs.com:5432/zhibotong?sslmode=require
# 首次部署前需先在 RDS 上执行 deploy/db/init.sql 建表
DATABASE_URL=

# ───────────────────────────────────────────────────────────────────────
#  ② 鉴权密钥（自定义 HMAC-SHA256 JWT 签名密钥）
#  登录 token 由本服务自己签发（/api/auth/login），与 Supabase Auth 无关
# ───────────────────────────────────────────────────────────────────────

# 随机字符串，≥32 字符；更换后所有已签发 token 失效（需重新登录）
JWT_SECRET=

# ───────────────────────────────────────────────────────────────────────
#  ② 阿里云 OSS（对象存储）
#  控制台：https://oss.console.aliyun.com
#  影响功能：文件/图片上传（主播导入文件、通用上传）
# ───────────────────────────────────────────────────────────────────────

# 地域，如 oss-cn-hangzhou
OSS_REGION=

# RAM 用户 AccessKey（建议仅授予对应 Bucket 的读写权限）
OSS_ACCESS_KEY_ID=
OSS_ACCESS_KEY_SECRET=

# Bucket 名称（需提前在 OSS 控制台创建，读写权限按需设为 public-read 或私有）
OSS_BUCKET=

# Endpoint（可选，留空时由 REGION 推导），形如 https://oss-cn-hangzhou.aliyuncs.com
OSS_ENDPOINT=

# 自定义域名 / CDN（可选）。留空时上传 URL 走 OSS 默认外网域名
OSS_CDN_DOMAIN=


# ───────────────────────────────────────────────────────────────────────
#  ③ 应用标识（⚠️ 非企业微信集成，无 API 调用）
#  APP_ID 仅用于构造匿名访客身份 free_visitor_{APP_ID}，任意字符串即可
# ───────────────────────────────────────────────────────────────────────
APP_ID=


# ───────────────────────────────────────────────────────────────────────
#  ④ 腾讯文档（按需接入，未用到可留空）
# ───────────────────────────────────────────────────────────────────────

TENCENT_DOCS_CLIENT_ID=
TENCENT_DOCS_ACCESS_TOKEN=
TENCENT_DOCS_OPEN_ID=
